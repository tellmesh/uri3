{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/workflow_graph.schema.json",
  "title": "URI Workflow Graph",
  "type": "object",
  "required": ["id", "nodes"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "integer", "default": 1 },
    "kind": {
      "type": "string",
      "enum": ["task", "workflow", "dependency"]
    },
    "description": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "uri", "operation"],
      "properties": {
        "id": { "type": "string" },
        "uri": { "type": "string" },
        "operation": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["query", "command", "assertion", "artifact", "domain_pack", "agent", "deployment", "http", "log", "browser"]
        },
        "type": { "type": "string" },
        "payload": { "type": "object" },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "condition": {
          "type": "object",
          "properties": {
            "if": { "type": "string" }
          }
        },
        "emits": {
          "type": "array",
          "items": { "type": "string" }
        },
        "produces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": { "type": "string" }
      }
    }
  }
}
