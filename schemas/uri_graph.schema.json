{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/uri_graph.schema.json",
  "title": "URI Graph Manifest",
  "type": "object",
  "required": ["uri_graph"],
  "properties": {
    "uri_graph": {
      "type": "object",
      "required": ["id", "version", "kind", "nodes"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "integer" },
        "kind": {
          "type": "string",
          "enum": ["task", "workflow", "dependency", "resource"]
        },
        "description": { "type": "string" },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "workflow_graph.schema.json#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "workflow_graph.schema.json#/$defs/edge" }
        }
      }
    }
  }
}
